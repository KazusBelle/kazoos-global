# --- Postgres ---
POSTGRES_DB=kazus
POSTGRES_USER=kazus
POSTGRES_PASSWORD=change-me

# --- Ports (host-side) ---
BACKEND_PORT=8000
FRONTEND_PORT=8080

# --- Auth ---
JWT_SECRET=please-change-me-to-a-long-random-string-of-32-bytes
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# --- Defaults ---
# CSV list of Binance USDT-M Futures symbols seeded on first boot.
DEFAULT_COINS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,AVAXUSDT,MATICUSDT,LINKUSDT,DOTUSDT,ARBUSDT

# --- CORS ---
# JSON list of allowed origins.
CORS_ORIGINS=["*"]

# --- Worker ---
REFRESH_INTERVAL_SEC=300
# Timeframes for which Telegram OTE alerts are sent. Comma-separated.
ALERT_TIMEFRAMES=D1,H1

# --- Telegram ---
# Leave empty to disable alerts (worker logs them instead).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
